<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Students</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body class="p-4">
  <div class="container">
    <h1 class="mb-4">Students</h1>

    <form method="post" action="/view/students" class="row g-2 mb-4">
      <div class="col-auto">
        <input name="name" required placeholder="Name" class="form-control" />
      </div>
      <div class="col-auto">
        <input name="roll" required type="number" min="1" placeholder="Roll" class="form-control" />
      </div>
      <div class="col-auto">
        <button class="btn btn-primary">Add</button>
      </div>
    </form>

    <table class="table table-striped">
      <thead>
        <tr><th>Roll</th><th>Name</th><th>Actions</th></tr>
      </thead>
      <tbody>
        <% students.forEach(function(s){ %>
          <tr>
            <td><%= s.roll %></td>
            <td><%= s.name %></td>
            <td>
              <a class="btn btn-sm btn-secondary" href="/view/students/edit/<%= s._id %>">Edit</a>
              <form method="post" action="/view/students/delete/<%= s._id %>" style="display:inline">
                <button class="btn btn-sm btn-danger">Delete</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</body>
</html>
