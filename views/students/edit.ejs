<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Edit Student</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body class="p-4">
  <div class="container">
    <h1 class="mb-4">Edit Student</h1>
    <form method="post" action="/view/students/edit/<%= student._id %>" class="row g-3">
      <div class="col-6">
        <label class="form-label">Name</label>
        <input name="name" value="<%= student.name %>" required class="form-control" />
      </div>
      <div class="col-3">
        <label class="form-label">Roll</label>
        <input name="roll" value="<%= student.roll %>" type="number" min="1" required class="form-control" />
      </div>
      <div class="col-3 d-flex align-items-end">
        <button class="btn btn-primary">Save</button>
        <a href="/view/students" class="btn btn-secondary ms-2">Cancel</a>
      </div>
    </form>
  </div>
</body>
</html>
